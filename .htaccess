Options -MultiViews
RewriteEngine On
RewriteBase /

# ============================================================
# GZIP / DEFLATE COMPRESSION
# ============================================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
  AddOutputFilterByType DEFLATE text/javascript application/javascript application/x-javascript
  AddOutputFilterByType DEFLATE application/json application/xml application/xhtml+xml
  AddOutputFilterByType DEFLATE image/svg+xml font/ttf font/otf font/woff font/woff2
  # Remove browser bugs
  BrowserMatch ^Mozilla/4 gzip-only-text/html
  BrowserMatch ^Mozilla/4\.0[678] no-gzip
  BrowserMatch \bMSIE !no-gzip !gzip-only-text/html
  Header append Vary User-Agent
</IfModule>

# ============================================================
# BROWSER CACHING
# ============================================================
<IfModule mod_expires.c>
  ExpiresActive On

  # Vendor bundles — never change, cache 1 year
  <FilesMatch "^vendor\.(css|js)$">
    ExpiresDefault "access plus 1 year"
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Site CSS/JS — cache 30 days (bump version string to bust)
  <FilesMatch "\.(css|js)$">
    ExpiresDefault "access plus 30 days"
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>

  # Images
  <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico)$">
    ExpiresDefault "access plus 6 months"
    Header set Cache-Control "public, max-age=15552000"
  </FilesMatch>

  # Fonts
  <FilesMatch "\.(woff|woff2|ttf|otf|eot)$">
    ExpiresDefault "access plus 1 year"
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# ============================================================
# SECURITY HEADERS
# ============================================================
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ============================================================
# CLEAN URLs — remove .php extension
# ============================================================

# 1. Strip .php extension — redirect /page.php to /page (301 permanent)
RewriteCond %{THE_REQUEST} \s/+(.+?)\.php[\s?] [NC]
RewriteRule ^ /%1 [R=301,NE,L]

# 2. Internally resolve clean URLs to their .php files
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+?)/?$ $1.php [L]
